{
  "name": "DocumentSource",
  "type": "object",
  "properties": {
    "workspace_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "relevance": {
      "type": "string",
      "enum": [
        "hoch",
        "mittel",
        "niedrig"
      ],
      "default": "mittel"
    },
    "owner": {
      "type": "string"
    },
    "added_by": {
      "type": "string"
    },
    "last_reviewed_at": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "neu",
        "relevant",
        "veraltet",
        "archiviert"
      ],
      "default": "neu"
    },
    "notes": {
      "type": "string"
    },
    "file_url": {
      "type": "string"
    }
  },
  "required": [
    "workspace_id",
    "title"
  ]
}